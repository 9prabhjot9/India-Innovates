# ── Project Theia Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values

# ── Database Credentials ───────────────────────────────────────────────────
NEO4J_PASSWORD=theia_secure_2025
POSTGRES_PASSWORD=theia_secure_2025

# ── LLM API Keys (required for Scenario Engine) ─────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Data Source API Keys ─────────────────────────────────────────────────────
# News APIs
NEWSAPI_KEY=your_newsapi_key
GDELT_API_KEY=your_gdelt_key

# Financial data
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
QUANDL_KEY=your_quandl_key

# Geospatial data
MAPBOX_TOKEN=your_mapbox_token
SENTINEL_HUB_KEY=your_sentinel_hub_key

# ── Kafka Configuration ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Application Settings ─────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your_secret_key_here_min_32_chars
